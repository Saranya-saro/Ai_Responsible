import numpy as np
from sklearn.linear_model import LinearRegression

# True relationship: y = 2x
X = np.array([1, 2, 3, 4, 5]).reshape(-1, 1)
y_clean = np.array([2, 4, 6, 8, 10])

# Scenario 1: Clean Data
model_clean = LinearRegression().fit(X, y_clean)
print(f"Clean Data Score: {model_clean.score(X, y_clean)}") # Perfect

# Scenario 2: Adding 'noisy' (irrelevant) data
y_noisy = np.array([2, 400, 6, 8, 10]) # One huge error
model_noisy = LinearRegression().fit(X, y_noisy)
print(f"Noisy Data Score: {model_noisy.score(X, y_noisy)}") # Significantly lower

