import pandas as pd

def check_fairness(data, sensitive_attr, target):
    """Checks for disparity in outcomes across sensitive groups."""
    grouped = data.groupby(sensitive_attr)[target].mean()
    print("Fairness Audit Check (Approval Rates):")
    print(grouped)
    # Accountability: If disparity > threshold, block deployment
    if abs(grouped.diff().max()) > 0.1:
        return "Action Needed: Bias Detected"
    return "Passed"

# Dummy data
df = pd.DataFrame({
    'gender': ['F''F''M''M']'approved': [0.5, 0.6, 0.8, 0.9]
})
print(check_fairness(df'gender''approved'))
