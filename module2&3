import pandas as pd
from sklearn.model_selection import train_test_split

# Load dataset
df = pd.read_csv("loan_applications.csv")

# Check representation of groups (fairness check)
print("Gender distribution:")
print(df['gender'].value_counts(normalize=True))

print("\nRace distribution:")
print(df['race'].value_counts(normalize=True))

# Handle missing values
df['income'].fillna(df['income'].median(), inplace=True)

# Split dataset with stratification
train, test = train_test_split(df, test_size=0.2, stratify=df['approved'], random_state=42)


# --------------------------------
# 2. Model Training & Development
# --------------------------------
from fairlearn.reductions import ExponentiatedGradient, DemographicParity
from sklearn.linear_model import LogisticRegression

# Define sensitive feature
sensitive_features = train['gender']

# Prepare training data
X_train = train.drop('approved', axis=1)
y_train = train['approved']

# Train fairness-aware model
classifier = LogisticRegression(max_iter=1000)
mitigator = ExponentiatedGradient(classifier, constraints=DemographicParity())

mitigator.fit(X_train, y_train, sensitive_features=sensitive_features)


# --------------------------------
# 3. Model Evaluation & Audit
# --------------------------------
from fairlearn.metrics import demographic_parity_difference

# Prepare test data
X_test = test.drop('approved', axis=1)
y_test = test['approved']

# Predictions
y_pred = mitigator.predict(X_test)

# Fairness evaluation
dp_diff = demographic_parity_difference(
    y_test,
    y_pred,
    sensitive_features=test['gender']
)

print("\nDemographic Parity Difference:", dp_diff)


# --------------------------------
# 4. Explainability & Interpretation
# --------------------------------
import shap

# Create SHAP explainer
explainer = shap.Explainer(mitigator.predict, X_test)

# Compute SHAP values
shap_values = explainer(X_test)

# Show feature importance
shap.summary_plot(shap_values, X_test)


