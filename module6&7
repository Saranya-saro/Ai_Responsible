import os
from openai import OpenAI

# Set your OpenAI API key as an environment variable for security
# Ensure you have 'pip install openai'
# os.environ["OPENAI_API_KEY"] = "YOUR_API_KEY" 
client = OpenAI(api_key=os.environ.get("OPENAI_API_KEY"))

def generate_story(prompt):
    """Generates a short story based on a prompt using the OpenAI API."""
    try:
        response = client.chat.completions.create(
            model="gpt-3.5-turbo",  # Or other models like gpt-4
            messages=[
                {"role": "system", "content": "You are a creative storyteller."},
                {"role": "user", "content": prompt}
            ],
            max_tokens=200,      # Controls the length of the response
            temperature=0.8,     # Controls the creativity (higher is more creative)
        )
        return response.choices[0].message.content
    except Exception as e:
        return f"An error occurred: {e}"

# Example usage
prompt = "Once upon a time, in a small village nestled between the mountains, a young girl discovered a magical key."
story = generate_story(prompt)
print(story)


  def calculate_factorial(n):
    """
    This function calculates the factorial of a given number using recursion.
    If the number is 0, it returns 1.
    """
    if n == 0:
        return 1
    else:
        return n * calculate_factorial(n - 1)

# Example usage
number = 5
print(f"The factorial of {number} is: {calculate_factorial(number)}")

  
