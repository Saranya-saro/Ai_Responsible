import torch
from transformers import pipeline

def detect_ai_text_model(text):
    """Uses a pre-trained transformer model to detect AI text."""
    # This model is a fine-tuned RoBERTa base model by OpenAI
    detector = pipeline('text-classification', model='openai-community/roberta-base-openai-detector')
    result = detector(text)
    # The 'FAKE' label indicates AI-generated content for this specific model
    is_ai = result[0]['label'] == 'FAKE' and result[0]['score'] > 0.5 
    score = result[0]['score'] if is_ai else 1 - result[0]['score']

    return is_ai, score

# Example Usage:
ai_text = "This is a test paragraph generated by an AI model."
is_ai, score = detect_ai_text_model(ai_text)
print(f"Is AI generated: {is_ai}, Confidence Score: {score}")

